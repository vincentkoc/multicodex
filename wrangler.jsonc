{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "multicodex",
	"main": "src/worker.ts",
	"compatibility_date": "2026-06-14",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist/client",
		"not_found_handling": "single-page-application",
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "multicodex",
			"database_id": "47385b34-0dd7-4a60-b30a-3ee8850615ba",
		},
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "EVENT_ADMISSION",
				"class_name": "EventAdmission",
			},
			{
				"name": "ROOM_HUB",
				"class_name": "RoomHub",
			},
		],
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["RoomHub"],
		},
		{
			"tag": "v2",
			"new_sqlite_classes": ["EventAdmission"],
		},
	],
	"triggers": {
		"crons": ["*/2 * * * *"],
	},
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1,
	},
	"vars": {
		"ALLOWED_REPOS": "vincentkoc/multicodex,openclaw/gogcli",
		"CRABFLEET_API_URL": "https://crabfleet.openclaw.ai",
		"CRABFLEET_OWNER": "multicodex",
		"CRABFLEET_RUNTIME": "container",
		"DEFAULT_BASE_BRANCH": "main",
		"DEFAULT_REPO": "vincentkoc/multicodex",
		"MAX_ACTIVE_ROOMS": "20",
		"MULTICODEX_SIMULATION_MODE": "false",
		"OPENAI_MODEL": "gpt-5.4-mini",
	},
}
