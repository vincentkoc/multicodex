{
	"compilerOptions": {
		"allowJs": false,
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"lib": ["ES2024", "DOM"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2024",
		"types": ["node"]
	},
	"include": ["packages", "tests"]
}
