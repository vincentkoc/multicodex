{
	"compilerOptions": {
		"allowJs": false,
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"jsxImportSource": "preact",
		"lib": ["ES2024", "DOM", "WebWorker"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2024",
		"types": ["node"]
	},
	"include": ["src", "tests", "vite.config.ts", "worker-configuration.d.ts"]
}
